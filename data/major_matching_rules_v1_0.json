      {
        "field": "career_value_fit.stability_fit",
        "order": "desc",
        "condition": "student.career_value_tags.stability >= 4"
      },
      {
        "field": "career_value_fit.salary_ceiling",
        "order": "desc",
        "condition": "student.career_value_tags.high_income >= 4"
      },
      {
        "field": "catalog.maturity",
