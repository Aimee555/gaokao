{
  "metadata": {
    "project": "gaokao_major_recommendation",
    "file_name": "major_matching_rules_v1_0.json",
    "version": "1.0.0",
    "language": "zh-CN",
    "created_at": "2026-06-08 15:22:19",
    "description": "专业匹配规则文件。用于将学生画像、产业推荐结果、职业路径推荐结果、专业库进行匹配，输出专业A/B/C/D梯队。",
    "input_files": [
      "student_profile_output.json",
      "industry_recommendation_result.json",
      "career_recommendation_result.json",
      "major_library_v1_0.json"
    ],
    "output_file": "major_recommendation_result.json",
    "core_goal": "从职业路径Top5收敛到可报考、可解释、风险可控的本科专业推荐梯队。",
    "updated_at": "2026-06-09",
    "update_note_v1_0_1": "与 majorMatcher 实现对齐（修正旧规则与现有体系的不适配，沿用产业/职业层已验证的加固）：A) 排除项改用专业库每个专业自带的结构化 not_recommended_if（替代脆弱的'专业名关键词'匹配，避免如'健康''教育'误伤）；hard=no_programming/no_medicine/no_teaching/no_law，strong=no_factory_site/no_engineering/no_hospital/no_long_training/no_research/no_sales/no_design/no_media/avoid_master_required/avoid_high_competition，其余 soft。B) market_fit 的 market_scores 为1-5分制，须 (x-1)/4*100 映射到0-100（含 ai_resilience=6-ai_substitution_risk 与 city_fit）。C) ability_match 改门槛型(达标即满分，能力溢出不扣分)；interest_match 改需求加权供给型（按学生兴趣强度加权，专业兴趣值≥学生即满分，只在学生热爱而专业不engage时扣分）——因专业库 interest_tags 非区分性(37/131全同值、40/131≥80%为5)，对称匹配会误伤专注学生、全部压到B档以下；career_value_match 为需求加权供给型。D) 所有惩罚(education_gate+not_recommended_if+market自适应)按 root_cause 去重(同根因取最大)，非硬惩罚去重后封顶40。E) 学生选科未采集到(画像无任何 subject_* 标签)时，限选科专业标 need_verify 而非 ineligible（0=未知不代表排斥）；已答选科正常硬过滤。F) education_gate 的 accept_master/accept_long_training<=2 仅在标签已知(>0)时触发。G) 动态追问携带 options+tag_effects，可回灌画像重排；已答追问不再透出。H) 职业相关性用职业'规则排名'(不叠加职业AI复核延迟)。",
    "design_principle": [
      "专业推荐必须以职业路径为主线，不直接从热门产业或画像跳到专业。",
      "新高考选科要求是硬门槛；选科不满足required_all的专业不得进入A/B主推荐。",
      "本规则中的选科要求只基于专业库通用模板；正式报考必须接入各省考试院和高校当年招生专业选考科目要求。",
      "AI可以做解释、追问和复核，但不允许覆盖选科硬过滤、排除项和专业目录边界。",
      "专业推荐不是就业承诺，必须展示风险、学历门槛、证书要求和大学准备路径。",
      "新增专业必须谨慎展示，不能仅因名字新或政策热就作为强推荐。"
    ],
    "risk_control_position": "本规则位于最终专业推荐前，是高影响决策的关键约束层。"
  },
  "input_schema": {
    "student_profile": {
      "required_groups": [
        "career_value_tags",
        "interest_tags",
        "ability_tags",
        "risk_tolerance_tags",
        "education_plan_tags",
        "exclusion_tags",
        "constraint_tags"
      ],
      "optional_groups": [
        "learning_style_tags",
        "work_scene_tags",
        "profile_type",
        "followup_answers",
        "raw_custom_answers"
      ],
      "new_gaokao_subject_tags": [
        "constraint_tags.subject_physics",
        "constraint_tags.subject_chemistry",
        "constraint_tags.subject_biology",
        "constraint_tags.subject_history",
        "constraint_tags.subject_politics",
        "constraint_tags.subject_geography",
        "constraint_tags.subject_technology"
      ],
      "numeric_tag_scale": {
        "min": 0,
        "max": 5,
        "note": "0表示未知或未采集，不等于排斥。1=很低，5=很高。"
      }
    },
    "career_recommendation_result": {
      "required_fields": [
        "recommended_careers"
      ],
      "recommended_careers_required_fields": [
        "career_id",
        "career_name",
        "score",
        "level",
        "entry_majors",
        "related_majors"
      ],
      "recommended_usage": "专业候选必须优先来自职业路径Top5的entry_majors和related_majors。"
    },
    "major_library": {
      "required_fields_per_major": [
        "major_id",
        "major_name",
        "catalog",
        "new_gaokao_subject_requirement_template",
        "related_careers",
        "related_industries",
        "ability_requirements",
        "career_value_fit",
        "education_profile",
        "market_scores",
        "not_recommended_if",
        "risk_notes"
      ]
    }
  },
  "candidate_generation_rules": {
    "description": "候选专业生成阶段只产生可排序候选，不直接决定最终推荐。",
    "primary_sources": [
      {
        "source": "career_recommendation_result.recommended_careers.entry_majors",
        "priority": 1,
        "weight": "highest",
        "description": "职业路径入口专业，优先级最高。"
      },
      {
        "source": "career_recommendation_result.recommended_careers.related_majors",
        "priority": 2,
        "weight": "high",
        "description": "职业路径相关专业，作为主候选。"
      },
      {
        "source": "major_library.indexes.career_major_index",
        "priority": 3,
        "weight": "high",
        "description": "通过职业ID反查专业库，补全候选。"
      },
      {
        "source": "industry_recommendation_result.recommended_industries.related_majors or major_library.indexes.industry_major_index",
        "priority": 4,
        "weight": "medium",
        "description": "产业相关专业只能作为补充候选，不能压过职业路径入口专业。"
      }
    ],
    "candidate_scope": {
      "main_careers_top_n": 5,
      "backup_careers_top_n": 3,
      "industries_top_n": 3,
      "max_candidates_before_filter": 50,
      "max_candidates_after_filter": 30
    },
    "do_not_do": [
      "不要对全专业库直接全局排序作为主推荐。",
      "不要仅因为产业政策热度高就把相关专业加入A类。",
      "不要把未在major_library_v1_0.json中的专业作为正式推荐。AI生成的新名称只能放入“需人工核验”。"
    ],
    "candidate_relevance_base_scores": {
      "from_top1_career_entry_major": 100,
      "from_top2_3_career_entry_major": 94,
      "from_top4_5_career_entry_major": 88,
      "from_top1_career_related_major": 86,
      "from_top2_3_career_related_major": 80,
      "from_top4_5_career_related_major": 74,
      "from_top_industry_related_major": 62,
      "from_user_declared_interest": 70,
      "from_ai_suggested_but_not_in_library": 0
    },
    "candidate_deduplication": {
      "rule": "同一专业只保留一次，合并来源证据source_evidence。",
      "source_evidence_fields": [
        "matched_career_ids",
        "matched_career_names",
        "matched_industry_ids",
        "matched_industry_names",
        "source_type"
      ]
    }
  },
  "hard_gate_rules": {
    "description": "硬门槛规则先于分数计算执行。",
    "subject_eligibility": {
      "rule_code": "new_gaokao_subject_required_all",
      "condition": "major.new_gaokao_subject_requirement_template.required_all not subset of student selected subjects",
      "action": "not_eligible",
      "allowed_output_bucket": "ineligible_majors",
      "can_enter_A_or_B": false,
      "can_enter_C": false,
      "display_label": "选科不符/不可报考",
      "reason_template": "该专业通常要求{required_subjects}，你的选科未满足。最终以所在省份和目标高校当年选科要求为准。",
      "important_note": "专业库中的选科要求为通用模板，正式系统必须接入省级选科要求数据。"
    },
    "hard_exclusion": {
      "rule_code": "student_explicit_exclusion",
      "condition": "student.exclusion_tags conflicts with major.not_recommended_if hard conditions",
      "action": "exclude_from_main_recommendation",
      "allowed_output_bucket": "not_recommended_majors",
      "can_enter_A_or_B": false,
      "reason_template": "你明确排斥该专业对应的核心学习或职业场景，因此不作为主推荐。"
    },
    "non_catalog_major": {
      "rule_code": "major_not_in_library",
      "condition": "major_name not in major_library.indexes.major_name_index",
      "action": "manual_review_required",
      "can_enter_A_or_B": false,
      "reason_template": "该专业不在当前专业库中，需核验是否为教育部本科专业目录中的正式专业。"
    },
    "medical_body_check_warning": {
      "rule_code": "medical_physical_exam_requirement",
      "condition": "major.catalog.discipline_category == '医学'",
      "action": "warning",
      "note": "医学类专业还需关注体检、色盲色弱、单科成绩、培养年限等高校招生章程要求。"
    }
  },
  "score_formula": {
    "final_score": {
      "formula": "final_score = career_relevance*0.30 + ability_match*0.20 + interest_match*0.15 + career_value_match*0.15 + market_fit*0.10 + education_fit*0.10 - exclusion_penalty - education_penalty - market_penalty - new_major_uncertainty_penalty",
      "min_score": 0,
      "max_score": 100,
      "rounding": "round_to_integer",
      "note": "先执行hard_gate_rules，再计算分数。选科不符专业不进入正常打分排序。"
    },
    "dimension_weights": {
      "career_relevance": 0.3,
      "ability_match": 0.2,
      "interest_match": 0.15,
      "career_value_match": 0.15,
      "market_fit": 0.1,
      "education_fit": 0.1
    },
    "career_relevance": {
      "scale": "0-100",
      "calculation": "根据专业候选来源、命中的职业路径排名、职业路径分数、entry_major/related_major关系综合计算。",
      "source_type_weights": {
        "entry_major": 1.0,
        "related_major": 0.82,
        "industry_related_major": 0.62,
        "user_declared_interest": 0.7
      },
      "career_rank_scores": {
        "rank_1": 100,
        "rank_2": 94,
        "rank_3": 88,
        "rank_4": 80,
        "rank_5": 74,
        "backup": 60
      },
      "multiple_career_bonus": {
        "bonus_per_extra_matched_career": 3,
        "max_bonus": 9,
        "description": "同一专业能通向多个高匹配职业路径时，可获得少量加分。"
      }
    },
    "ability_match": {
      "scale": "0-100",
      "calculation": "比较student.ability_tags与major.ability_requirements。",
      "ability_mapping": {
        "ability_tags.math": "ability_requirements.math_requirement",
        "ability_tags.logic": "ability_requirements.logic_requirement",
        "ability_tags.physics": "ability_requirements.physics_requirement",
        "ability_tags.chemistry_biology": "ability_requirements.chemistry_biology_requirement",
        "ability_tags.programming_acceptance": "ability_requirements.programming_requirement",
        "ability_tags.memory": "ability_requirements.memory_requirement",
        "ability_tags.language_expression": "ability_requirements.language_expression_requirement",
        "ability_tags.communication": "ability_requirements.communication_requirement",
        "ability_tags.hands_on": "ability_requirements.hands_on_requirement",
        "ability_tags.aesthetic": "ability_requirements.aesthetic_requirement"
      }
    },
    "interest_match": {
      "scale": "0-100",
      "calculation": "优先使用major.match_tags中的interest_tags与学生兴趣标签匹配；若缺失则参考相关职业match_tags。",
      "supporting_rule": "兴趣只是必要参考，不可覆盖能力、选科和职业路径相关性。"
    },
    "career_value_match": {
      "scale": "0-100",
      "calculation": "比较学生career_value_tags和major.career_value_fit。",
      "value_mapping": {
        "career_value_tags.high_income": "career_value_fit.high_income_fit",
        "career_value_tags.stability": "career_value_fit.stability_fit",
        "career_value_tags.technical_barrier": "career_value_fit.technical_barrier_fit",
        "career_value_tags.undergrad_employment": "career_value_fit.undergrad_employment_fit",
        "career_value_tags.public_sector": "career_value_fit.public_sector_fit",
        "career_value_tags.work_life_balance": "career_value_fit.work_life_balance_fit",
        "career_value_tags.local_development": "career_value_fit.local_development_fit",
        "career_value_tags.ai_resilience": "career_value_fit.ai_resilience_fit"
      }
    },
    "market_fit": {
      "scale": "0-100",
      "base_formula": "undergrad_employment_score*0.25 + job_volume_score*0.20 + salary_potential_score*0.20 + stability_score*0.15 + ai_resilience_score*0.10 + city_fit_score*0.10",
      "city_fit_rule": {
        "if_student_big_city_tolerance_low_and_major_city_concentration_high": "city_fit_score=1",
        "if_student_city_flexible": "city_fit_score=3",
        "otherwise": "city_fit_score=5 - abs(student.big_city_tolerance - major.city_concentration)"
      },
      "ai_resilience_rule": "ai_resilience_score = 6 - major.market_scores.ai_substitution_risk"
    },
    "education_fit": {
      "scale": "0-100",
      "calculation": "根据学生prefer_undergrad_employment、accept_master、accept_phd、accept_certificate与major.education_profile匹配。",
      "rules": [
        "本科就业优先且专业undergrad_friendly_score高 → 加分。",
        "不愿读研且专业master_requirement_score高 → 降分。",
        "不愿考证且专业certificate_requirement_score高 → 降分。",
        "不接受长期培养且专业long_training_score高 → 降分。"
      ]
    },
    "single_numeric_tag_match": {
      "formula": "match = 1 - abs(student_value - required_value) / 4",
      "clamp": {
        "min": 0,
        "max": 1
      },
      "unknown_student_tag_strategy": {
        "student_value_0": {
          "default_match": 0.55,
          "note": "0表示未知，不按最低分处理。"
        }
      }
    }
  },
  "subject_filter_rules": {
    "selected_subject_mapping": {
      "constraint_tags.subject_physics": "物理",
      "constraint_tags.subject_chemistry": "化学",
      "constraint_tags.subject_biology": "生物",
      "constraint_tags.subject_history": "历史",
      "constraint_tags.subject_politics": "政治",
      "constraint_tags.subject_geography": "地理",
      "constraint_tags.subject_technology": "技术"
    },
    "required_all": {
      "action_if_not_satisfied": "ineligible",
      "score_penalty": 999,
      "display": "选科不符/不可报考",
      "note": "不满足required_all不得进入A/B/C推荐。"
    },
    "recommended": {
      "action_if_not_satisfied": "warning_only",
      "score_penalty": 0,
      "display": "建议具备相关学科基础",
      "note": "recommended不是硬过滤，只作为能力和学习风险提示。"
    },
    "unknown_or_empty_requirement": {
      "action": "allow_but_warn",
      "display": "需核验目标高校选科要求",
      "note": "专业库没有明确required_all时不做硬排除，但正式报考必须核验。"
    },
    "province_university_override_policy": {
      "rule": "如果接入省考试院/高校当年专业组选科要求，则以外部权威数据覆盖本库模板。",
      "priority": "external_official_requirement > major_library_template"
    }
  },
  "education_gate_rules": {
    "rules": [
      {
        "rule_code": "undergrad_employment_vs_master_required",
        "condition": "student.education_plan_tags.prefer_undergrad_employment >= 4 and major.education_profile.master_requirement_score >= 4",
        "action": "downgrade_or_deep_study_bucket",
        "penalty": 18,
        "cannot_enter_A_unless": "career_relevance >= 92 and student.education_plan_tags.accept_master >= 4",
        "reason": "学生希望本科就业，但该专业高质量路径较依赖研究生学历。"
      },
      {
        "rule_code": "reject_master_penalty",
        "condition": "student.education_plan_tags.accept_master <= 2 and major.education_profile.master_requirement_score >= 4",
        "action": "strong_penalty",
        "penalty": 30,
        "reason": "学生不愿读研，但该专业读研依赖较高。"
      },
      {
        "rule_code": "reject_long_training_penalty",
        "condition": "student.education_plan_tags.accept_long_training <= 2 and major.education_profile.long_training_score >= 4",
        "action": "strong_penalty",
        "penalty": 35,
        "reason": "学生不接受长期培养，但该专业培养周期较长。"
      },
      {
        "rule_code": "certificate_requirement_penalty",
        "condition": "student.learning_style_tags.certificate_learning <= 2 and major.education_profile.certificate_requirement_score >= 4",
        "action": "warning_penalty",
        "penalty": 12,
        "reason": "该专业相关路径通常需要证书或资格考试，但学生考证接受度较低。"
      },
      {
        "rule_code": "future_or_new_major_caution",
        "condition": "major.catalog.maturity contains '2025新增'",
        "action": "new_major_uncertainty_penalty",
        "penalty": 6,
        "reason": "新增专业培养方案和就业反馈尚需验证，不宜仅因概念新而强推。"
      }
    ]
  },
  "exclusion_and_penalty_rules": {
    "hard_exclusions": [
      {
        "tag": "exclusion_tags.no_programming",
        "target_major_keywords": [
          "计算机",
          "软件",
          "人工智能",
          "数据科学",
          "信息安全",
          "网络空间",
          "物联网",
          "工业软件"
        ],
        "penalty": 70,
        "reason": "学生明确排斥编程。"
      },
      {
        "tag": "exclusion_tags.no_medicine",
        "target_major_keywords": [
          "临床",
          "口腔",
          "医学",
          "药学",
          "护理",
          "康复",
          "健康"
        ],
        "penalty": 70,
        "reason": "学生明确排斥医学或医疗环境。"
      },
      {
        "tag": "exclusion_tags.no_teaching",
        "target_major_keywords": [
          "教育",
          "小学教育",
          "学前教育",
          "思想政治教育"
        ],
        "penalty": 50,
        "reason": "学生明确不想当老师或走师范教育路径。"
      },
      {
        "tag": "exclusion_tags.no_law",
        "target_major_keywords": [
          "法学",
          "知识产权",
          "政治学"
        ],
        "penalty": 50,
        "reason": "学生明确排斥法律相关方向。"
      }
    ],
    "strong_penalties": [
      {
        "tag": "exclusion_tags.no_factory_site",
        "target_major_classes": [
          "机械类",
          "材料类",
          "化工与制药类",
          "土木类",
          "电气类",
          "能源动力类",
          "航空航天类"
        ],
        "penalty": 25,
        "reason": "学生不希望工厂、工程现场或外勤场景。"
      },
      {
        "tag": "exclusion_tags.no_sales",
        "target_major_keywords": [
          "市场营销",
          "电子商务",
          "国际经济与贸易",
          "商务英语",
          "保险学"
        ],
        "penalty": 25,
        "reason": "学生排斥销售或强客户沟通。"
      },
      {
        "tag": "constraint_tags.avoid_ai_substitution_risk",
        "condition": "major.market_scores.ai_substitution_risk >= 4",
        "penalty": 15,
        "reason": "学生希望规避AI替代风险。"
      },
      {
        "tag": "constraint_tags.avoid_high_competition",
        "condition": "major.market_scores.competition_level >= 4",
        "penalty": 15,
        "reason": "学生希望规避高竞争。"
      },
      {
        "tag": "constraint_tags.avoid_master_required",
        "condition": "major.education_profile.master_requirement_score >= 4",
        "penalty": 22,
        "reason": "学生希望规避读研依赖。"
      }
    ],
    "soft_penalties": [
      {
        "tag": "constraint_tags.avoid_unclear_path",
        "condition": "major.career_relation_strength == 'curated' or major.entry_career_count <= 1",
        "penalty": 8,
        "reason": "就业路径相对不清晰或职业映射较少。"
      },
      {
        "tag": "constraint_tags.avoid_low_income_ceiling",
        "condition": "major.career_value_fit.salary_ceiling <= 3",
        "penalty": 10,
        "reason": "学生希望规避收入上限低。"
      },
      {
        "tag": "constraint_tags.avoid_big_city_concentration",
        "condition": "major.market_scores.city_concentration >= 4",
        "penalty": 10,
        "reason": "学生希望规避大城市岗位集中。"
      }
    ]
  },
  "market_adaptive_rules": {
    "description": "就业市场规则必须根据学生目标自适应，不同学生对同一专业的风险感受不同。",
    "rules": [
      {
        "rule_code": "high_income_adjustment",
        "condition": "student.career_value_tags.high_income >= 4",
        "effect": "salary_potential_score_weight +0.05, stability_score_weight -0.03",
        "note": "高收入导向学生可适度提高薪资潜力权重。"
      },
      {
        "rule_code": "stability_adjustment",
        "condition": "student.career_value_tags.stability >= 4",
        "effect": "stability_score_weight +0.08, salary_potential_score_weight -0.03",
        "note": "稳定导向学生更看重就业稳定和本地/公共部门机会。"
      },
      {
        "rule_code": "local_development_adjustment",
        "condition": "student.career_value_tags.local_development >= 4 or student.risk_tolerance_tags.big_city_tolerance <= 2",
        "effect": "city_concentration_penalty +10 if major.market_scores.city_concentration >= 4",
        "note": "本地发展导向学生需惩罚大城市集中专业路径。"
      },
      {
        "rule_code": "undergrad_employment_adjustment",
        "condition": "student.education_plan_tags.prefer_undergrad_employment >= 4",
        "effect": "undergrad_employment_score_weight +0.08, master_requirement_penalty enabled",
        "note": "本科就业优先学生应优先推荐本科就业路径清晰专业。"
      }
    ]
  },
  "output_level_rules": {
    "A": {
      "min_score": 85,
      "max_score": 100,
      "label": "强推荐",
      "conditions": [
        "subject_eligible == true",
        "career_relevance >= 80",
        "no_hard_exclusion == true",
        "major.education_profile.master_requirement_score <= 4 or student.accept_master >= 4"
      ],
      "description": "职业路径相关性强、能力匹配较好、风险可接受。"
    },
    "B": {
      "min_score": 70,
      "max_score": 84,
      "label": "可考虑",
      "conditions": [
        "subject_eligible == true",
        "no_hard_exclusion == true"
      ],
      "description": "整体匹配较好，但存在一定学历、竞争、能力或城市门槛。"
    },
    "C": {
      "min_score": 55,
      "max_score": 69,
      "label": "谨慎考虑",
      "conditions": [
        "subject_eligible == true"
      ],
      "description": "有一定相关性，但不建议作为主推，需要结合院校层次、城市、学历规划继续判断。"
    },
    "D": {
      "min_score": 0,
      "max_score": 54,
      "label": "不推荐",
      "description": "匹配度较低或与排除条件、学历规划、风险偏好存在明显冲突。"
    },
    "INELIGIBLE": {
      "label": "选科不符/不可报考",
      "description": "学生选科不满足专业硬性选科模板，正式报考需核验目标高校当年要求。"
    }
  },
  "output_buckets": {
    "strong_recommend_majors": {
      "level": "A",
      "max_count": 5,
      "display_name": "A类：强推荐专业"
