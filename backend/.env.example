# DeepSeek API Key（必填）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 服务监听端口与地址
PORT=8787
HOST=0.0.0.0

# CORS 允许的前端来源（多个用逗号分隔，生产环境改成你的正式域名）
ALLOWED_ORIGINS=http://localhost:5173

# ── 滥用防护（免登录公开访问场景建议配置；不配则用下方默认值）────────────────

# 部署在 反向代理 / CDN / 网关 之后必须开启，否则 req.ip 拿到的是代理 IP，
# 导致按 IP 的限流对所有用户共用一个配额。本地直连保持 false。
# 取值：false（默认）/ true / 信任的代理跳数(如 1) / 具体 IP 段
TRUST_PROXY=false

# 全局每日 AI 调用上限：当天放行的真实 DeepSeek 调用次数，超出后复核降级为规则
# 结果、AI 报告返回 429。<=0 表示不限制。这是「限流之外」防被刷爆额度的总闸。
DEEPSEEK_DAILY_LIMIT=500

# 限流：滑动窗口与单 IP 上限
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_PER_IP=10
# 所有 IP 合计每窗口上限（防海量不同 IP 同时打爆），<=0 关闭
RATE_LIMIT_MAX_GLOBAL=0

# 单个请求体最大字节数，防超大 payload 放大 token 消耗（默认 256KB）
MAX_BODY_BYTES=262144

# ── 访问统计 / 埋点 ───────────────────────────────────────────────────────────

# 统计页/接口的管理口令。不配则整个统计功能关闭（/api/stats 返回 403）。
# 配置后访问 http://<后端>/api/stats/dashboard 输入此口令查看。
ADMIN_TOKEN=

# 埋点事件落库文件路径（JSONL，一行一事件）。默认 backend 目录下 analytics-events.jsonl。
# 注意：需部署在有持久磁盘的机器上（ECS/VPS）；serverless 临时盘会丢数据。
ANALYTICS_FILE=
